{
  "manifest_version": 3,
  "name": "Key Chatter",
  "version": "1.1.0",
  "description": "ExpertGPT side panel chat with single API key, model selection, quick prompts, and multilingual UI.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "clipboardRead"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Key Chatter - Chat with Webpage"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
